# ─── AutoReach Production Environment ───
# Copy this to .env on your server and fill in ALL values

NODE_ENV=production
PORT=3001

# Security — CHANGE THIS to a long random string (64+ chars)
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64

# Stripe (optional — leave as-is to disable billing)
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_WEBHOOK_SECRET=REPLACE_ME
STRIPE_PRICE_PRO=REPLACE_ME
STRIPE_PRICE_BUSINESS=REPLACE_ME
