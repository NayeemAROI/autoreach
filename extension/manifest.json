{
  "manifest_version": 3,
  "name": "LinkedIn Automation Bridge",
  "version": "1.0.0",
  "description": "Connects your local automation tool securely with your active LinkedIn session.",
  "permissions": [
    "cookies",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "ws://localhost/*",
    "ws://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background/index.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["src/content/index.js"]
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": ["src/content/app-sync.js"]
    }
  ],
  "action": {
    "default_popup": "index.html"
  }
}
